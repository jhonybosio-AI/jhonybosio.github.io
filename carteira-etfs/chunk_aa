    .tab-btn {
      background: transparent;
      border: 1px solid var(--gborder);
      color: rgba(255, 255, 255, 0.4);
      padding: .6rem 1.4rem;
      border-radius: 10px;
      cursor: pointer;
      font-family: var(--fb);
      font-weight: 600;
      font-size: .85rem;
      transition: all .25s;
    }

    .tab-btn.active {
      background: var(--blue);
      color: #fff;
      border-color: var(--blue);
      box-shadow: 0 0 20px rgba(0, 146, 255, .3);
    }

    .alloc-table {
      width: 100%;
      border-collapse: collapse;
    }

    .alloc-table thead tr {
      border-bottom: 1px solid var(--gborder);
    }

    .alloc-table th {
      padding: .75rem 1rem;
      text-align: left;
      font-size: .72rem;
      color: rgba(255, 255, 255, 0.4);
      text-transform: uppercase;
      letter-spacing: .07em;
      font-weight: 600;
    }

    .alloc-table th:not(:first-child) {
      text-align: center;
    }

    .alloc-table tbody tr {
      border-bottom: 1px solid rgba(255, 255, 255, .04);
      transition: background .2s;
    }

    .alloc-table tbody tr:hover {
      background: rgba(255, 255, 255, .03);
    }

    .alloc-table td {
      padding: .9rem 1rem;
      font-size: .9rem;
    }

    .alloc-table td:not(:first-child) {
      text-align: center;
      font-weight: 600;
    }

    .cat-label {
      font-weight: 700;
      color: #fff;
    }

    .sub-label {
      font-size: .8rem;
      color: rgba(255, 255, 255, 0.4);
    }

    .alloc-bar-wrap {
      height: 6px;
      background: rgba(255, 255, 255, .07);
      border-radius: 99px;
      margin-top: 4px;
    }

    .alloc-bar {
      height: 6px;
      border-radius: 99px;
      background: var(--blue);
      transition: width .6s ease;
    }

    .highlight-col {
      background: rgba(0, 146, 255, .05);
    }

    /* Profile cards */
    .profile-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    @media(max-width:700px) {
      .profile-cards {
        grid-template-columns: 1fr;
      }
    }

    .profile-card {
      border-radius: 20px;
      padding: 1.5rem;
      border: 1px solid var(--gborder);
      background: rgba(255, 255, 255, 0.02);
    }

    .profile-card.active-card {
      border-color: var(--blue);
      background: rgba(0, 146, 255, 0.07);
    }

    .profile-name {
      font-weight: 700;
      font-size: 1rem;
      margin-bottom: .4rem;
    }

    .profile-desc {
      font-size: .82rem;
      color: rgba(255, 255, 255, 0.4);
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .profile-risk {
      font-size: .75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      padding: .3rem .8rem;
      border-radius: 100px;
      display: inline-block;
    }

    .risk-low {
      background: rgba(16, 185, 129, .1);
      color: #10b981;
    }

    .risk-med {
      background: rgba(0, 146, 255, .1);
      color: var(--blue);
    }

    .risk-high {
      background: rgba(255, 204, 0, .1);
      color: #ffcc00;
    }

    footer {
      margin-top: 4rem;
      text-align: center;
      padding-bottom: 2rem;
      color: rgba(255, 255, 255, 0.4);
      font-size: .8rem;
    }

    @media(max-width:600px) {
      .wrap {
        padding: 1rem;
      }
    }

