  <style>
    :root {
      /* Blue3 Official Palette */
      --navy: #000d38;
      --navy-light: #002060;
      --blue: #0092ff;
      --bg: #050a1d;
      --w: #FFFFFF;
      --gb: rgba(255, 255, 255, 0.05);
      --gborder: rgba(255, 255, 255, 0.10);
      --gblur: blur(24px) saturate(1.6);
