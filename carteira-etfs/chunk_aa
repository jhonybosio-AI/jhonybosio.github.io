      font-size: 1.3rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: .75rem;
    }

    .widget-wrap {
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid var(--gborder);
    }

