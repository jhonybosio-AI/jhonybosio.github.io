      color: #fff;
      line-height: 1.1;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .logo-name::before {
      content: "|";
      color: rgba(255, 255, 255, 0.2);
      font-weight: 300;
    }

    .logo-sub {
      font-size: 9px;
      font-weight: 700;
      color: var(--blue);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-top: 1px;
    }

    nav a {
      color: rgba(255, 255, 255, 0.5);
      text-decoration: none;
      font-weight: 600;
      margin-left: 1.5rem;
      transition: color .2s;
      font-size: .85rem;
      text-transform: uppercase;
      letter-spacing: .05em;
    }

    nav a:hover {
      color: var(--blue);
    }

    .hero {
      margin-bottom: 3rem;
    }

    .badge {
      background: rgba(201, 168, 76, .1);
      color: var(--blue);
      display: inline-block;
      padding: .4rem 1rem;
      border-radius: 100px;
      font-size: .75rem;
      font-weight: 700;
      margin-bottom: 1rem;
      border: 1px solid rgba(201, 168, 76, .2);
    }

    .hero h1 {
      font-size: clamp(2.2rem, 5vw, 3.5rem);
      line-height: 1.05;
      font-weight: 700;
      letter-spacing: -.03em;
      margin-bottom: 1rem;
    }

    .blue {
      color: var(--blue);
    }

    .gold {
      color: var(--gold);
    }

    .hero p {
      color: var(--muted);
      font-size: 1.05rem;
      max-width: 640px;
      line-height: 1.7;
    }

    .glass {
      background: var(--card-bg);
      backdrop-filter: blur(24px);
      border: 1px solid var(--glass-border);
      border-radius: 24px;
      padding: 2rem;
      position: relative;
      overflow: hidden;
      transition: transform .3s;
    }

    .glass::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(255, 255, 255, .2), transparent);
    }

    .glass:hover {
      transform: translateY(-4px);
    }

    /* Philosophy */
    .philosophy {
      margin-bottom: 3rem;
    }

    .philosophy h2 {
      font-size: 1.3rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: .75rem;
    }

    .pillar-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .pillar {
      background: var(--card-bg);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 1.5rem;
    }

    .pillar-icon {
      font-size: 1.6rem;
      margin-bottom: .75rem;
    }

    .pillar h3 {
      font-size: .95rem;
      font-weight: 700;
      margin-bottom: .5rem;
    }

    .pillar p {
      font-size: .85rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* Market widget */
    .market-section {
