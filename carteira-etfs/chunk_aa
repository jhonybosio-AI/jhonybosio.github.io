      background: linear-gradient(135deg, var(--blue), var(--navy-light));
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      color: #fff;
      font-size: 14px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 4px 12px rgba(0, 146, 255, 0.2);
    }

    .logo-text {
      display: flex;
      flex-direction: column;
    }

    .logo-name {
      font-weight: 800;
